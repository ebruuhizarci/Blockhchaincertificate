# Supabase PostgreSQL (pooler)
DB_HOST=your-project.pooler.supabase.com
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-supabase-db-password
DB_PORT=6543
DB_SSLMODE=require
DB_CONNECT_TIMEOUT=10

# Belge mühürleme ücreti (TRY)
PAYMENT_AMOUNT_TRY=50.0

# iyzico (sandbox: https://sandbox-merchant.iyzipay.com)
IYZICO_API_KEY=sandbox-your-api-key
IYZICO_SECRET_KEY=sandbox-your-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Ödeme dönüş adresleri (canlıda ngrok veya gerçek domain)
BACKEND_PUBLIC_URL=http://127.0.0.1:5000
FRONTEND_URL=http://localhost:5173

# Sunucu cüzdanı — ödeme sonrası blockchain yazımı (MetaMask private key, 0x...)
RELAYER_PRIVATE_KEY=

# Kontrat (boşsa frontend/config/contracts.json kullanılır)
VITE_CONTRACT_ADDRESS=
VITE_RPC_URL=https://rpc-amoy.polygon.technology
VITE_CHAIN_ID=80002

# Yerel test: gerçek iyzico olmadan ödeme simülasyonu
IYZICO_MOCK=true

# Admin panel giriş bilgisi
ADMIN_EMAIL=admin@etherescan.local
ADMIN_PASSWORD=admin123
